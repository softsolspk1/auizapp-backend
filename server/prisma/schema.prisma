datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             Int           @id @default(autoincrement())
  doctorName     String
  designation    String
  specialty      String
  hospitalName   String
  pmdcNumber     String        @unique
  city           String
  phoneNumber    String
  email          String        @unique
  password       String
  isApproved     Boolean       @default(false)
  isActive       Boolean       @default(true)
  role           String        @default("user") // "user" or "admin"
  permissions    String[]      @default([]) // For subadmin specific access
  totalPoints    Int           @default(0)
  gamesPlayed    Int           @default(0)
  correctAnswers Int           @default(0)
  wrongAnswers   Int           @default(0)
  lastLogin      DateTime?
  level          Int           @default(1)
  badges         String[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  quizSessions   QuizSession[]
  pinsCreated    Pin[]
}

model Category {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  description   String?
  isActive      Boolean       @default(true)
  questionCount Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  questions     Question[]
  quizSessions  QuizSession[]
  pins          Pin[]
}

model Question {
  id            Int           @id @default(autoincrement())
  question      String
  options       String[]
  correctAnswer Int
  explanation   String?
  categoryId    Int
  category      Category      @relation(fields: [categoryId], references: [id])
  difficulty    String        @default("medium") // "easy", "medium", "hard"
  isActive      Boolean       @default(true)
  timesAnswered Int           @default(0)
  correctCount  Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessionQuestions QuizSessionQuestion[]
}

model QuizSession {
  id             Int                   @id @default(autoincrement())
  userId         Int
  user           User                  @relation(fields: [userId], references: [id])
  categoryId     Int
  category       Category              @relation(fields: [categoryId], references: [id])
  score          Int                   @default(0)
  totalQuestions Int
  correctAnswers Int                   @default(0)
  wrongAnswers   Int                   @default(0)
  timeSpent      Int                   @default(0)
  gameMode       String                // "single", "multiplayer", "pin"
  roomId         String?
  pin            String?               // For PIN based quizzes
  isCompleted    Boolean               @default(false)
  completedAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  questions      QuizSessionQuestion[]
}

model QuizSessionQuestion {
  id            Int         @id @default(autoincrement())
  quizSessionId Int
  quizSession   QuizSession @relation(fields: [quizSessionId], references: [id], onDelete: Cascade)
  questionId    Int?
  question      Question?   @relation(fields: [questionId], references: [id], onDelete: SetNull)
  userAnswer    Int?
  isCorrect     Boolean?
  timeSpent     Int?
}

model Pin {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  wardName    String
  city        String
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  questionIds Int[]
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  creatorId   Int
  creator     User     @relation(fields: [creatorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
